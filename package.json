{
  "name": "colour-fun",
  "version": "1.0.0",
  "private": true,
  "description": "colour&fun — pixel-perfect solid background generator (FSDE 2025 DevOps repo)",
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint --prefix solid-colour",
    "format": "prettier --write \"solid-colour/src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"solid-colour/src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,md,yml,yaml}\"",
    "test": "npm test --prefix solid-colour",
    "test:ci": "npm run test:ci --prefix solid-colour",
    "build": "npm run build --prefix solid-colour"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "solid-colour/src/**/*.{ts,tsx,js,jsx,css,md}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "react-colorful": "^5.6.1"
  }
}
